# ECHO AI — Environment Variables
# Copy this file to .env and fill in your values.

# ── LLM ─────────────────────────────────────────────
ACTIVE_PROVIDER=ollama              # "ollama" | "local_openai"
DEFAULT_MODEL=llama3.1:8b
OLLAMA_ENDPOINT=http://localhost:11434
LOCAL_OPENAI_URL=http://localhost:1234/v1   # LM Studio / llama.cpp

# ── Features ─────────────────────────────────────────
ENABLE_RAG=True
ENABLE_WEB=False
ENABLE_WEATHER=True
DEFAULT_LOCATION=Belgrade

# ── Research ─────────────────────────────────────────
MAX_RESEARCH_DEPTH=3
MAX_EXECUTION_TIME=30

# ── Mode ─────────────────────────────────────────────
ECHO_MODE=desktop                   # "desktop" | "portable"
ECHO_STORAGE_ROOT=./data

# ── Security (optional) ───────────────────────────────
ECHO_API_KEY=                       # Leave blank = no auth
ECHO_ENCRYPT=false
ECHO_ENCRYPT_KEY=                   # Fernet key (auto-generated if blank)

# ── Database ──────────────────────────────────────────
DATABASE_URL=sqlite:///./backend/assistant_memory.db
VECTOR_DB_PATH=./backend/vector_db
